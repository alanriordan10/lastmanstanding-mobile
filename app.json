{
  "expo": {
    "name": "Last Man Standing",
    "slug": "lastmanstanding-mobile",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lastmanstanding.app",
      "permissions": [],
      "versionCode": 4,
      "playStoreUrl": "",
      "blockedPermissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "@stripe/stripe-react-native"
    ],
    "scheme": "lastmanstanding",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e3a5137-9e9b-4612-b40c-5ce8d3a06b02"
      }
    },
    "description": "Run and play Last Man Standing football survivor competitions.",
    "privacy": "public",
    "owner": "alanriordan",
    "primaryColor": "#0ea5e9",
    "githubUrl": "https://github.com/alan/lastmanstanding-mobile"
  }
}
